# Firebase settings — copy this file as ".env.local" and fill it in.
# Get the values from Firebase Console > Project settings > Your apps (Web).
# If left empty, the app runs in "guest" mode (only on this device).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
