# Firebase ayarları — bu dosyayı ".env.local" olarak kopyala ve doldur.
# Değerleri Firebase Console > Project settings > Your apps (Web) bölümünden alırsın.
# Boş bırakırsan uygulama "misafir" modda (yalnızca bu cihazda) çalışır.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
